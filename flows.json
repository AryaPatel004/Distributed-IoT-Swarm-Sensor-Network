    {
        "id": "func_process_light",
        "type": "function",
        "z": "tab_assignment",
        "name": "Format Light Data",
        "func": "var rawData = msg.payload.data;\nvar map = {};\n\n// --- HARDCODED CONFIGURATION ---\nvar IP_COLOR_MAP = {\n    \"192.168.0.169\": \"#FF0000\", // Red\n    \"192.168.0.88\":  \"#008000\", // Green\n    \"192.168.0.220\": \"#0000FF\"  // Blue\n};\nvar DEFAULT_COLOR = \"#000000\"; // Black for unknown IPs\n// -------------------------------\n\n// 1. Group incoming data by IP\nrawData.forEach(function(d) {\n    if (!map[d.ip]) {\n        map[d.ip] = [];\n    }\n    map[d.ip].push({ x: d.x, y: d.y });\n});\n\nvar outSeries = [];\nvar outData = [];\nvar outColors = [];\n\nvar activeIPs = Object.keys(map).sort();\n\n// 2. Build arrays\nactiveIPs.forEach(function(ip){\n    outSeries.push(ip);\n    outData.push(map[ip]);\n    outColors.push(IP_COLOR_MAP[ip] || DEFAULT_COLOR);\n});\n\nmsg.payload = [{\n    series: outSeries,\n    data:   outData,\n    labels: [\"Light\"]\n}];\n\n// 3. FORCE colors for each series\nmsg.ui_control = {\n    colors: outColors\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 410,
        "y": 160,
        "wires": [
            [
                "chart_light_trace"
            ]
        ]
    },
