    {
        "id": "func_process_duration",
        "type": "function",
        "z": "tab_assignment",
        "name": "Format Bar Data",
        "func": "var rawData = msg.payload.data;\nvar map = {};\n\n// --- HARDCODED CONFIGURATION ---\nvar IP_COLOR_MAP = {\n    \"192.168.0.169\": \"#FF0000\", // Red\n    \"192.168.0.88\":  \"#008000\", // Green\n    \"192.168.0.220\": \"#0000FF\"  // Blue\n};\nvar DEFAULT_COLOR = \"#000000\"; \n// -------------------------------\n\n// 1. Group by IP\nrawData.forEach(function(d){\n    map[d.ip] = d.duration;\n});\n\nvar activeIPs = Object.keys(map).sort();\n\nvar outSeries = [];\nvar outData = [];\nvar outColors = [];\n\n// 2. Build Arrays\nactiveIPs.forEach(function(ip){\n    outSeries.push(ip);        // Series name = IP\n    outData.push([map[ip]]);   // One value per IP (one label: \"Duration\")\n\n    // Assign correct color\n    outColors.push(IP_COLOR_MAP[ip] || DEFAULT_COLOR);\n});\n\nmsg.payload = [{\n    series: outSeries,\n    data:   outData,\n    labels: [\"Duration\"]\n}];\n\n// 3. FORCE the colors for each series\nmsg.ui_control = {\n    colors: outColors\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 410,
        "y": 300,
        "wires": [
            [
                "chart_master_duration"
            ]
        ]
    },
